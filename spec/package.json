{
  "name": "@mighty-decks/spec",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adventureState": {
      "types": "./dist/adventureState.d.ts",
      "import": "./dist/adventureState.js"
    },
    "./actorCards": {
      "types": "./dist/actorCards.d.ts",
      "import": "./dist/actorCards.js"
    },
    "./assetCards": {
      "types": "./dist/assetCards.d.ts",
      "import": "./dist/assetCards.js"
    },
    "./campaign": {
      "types": "./dist/campaign.d.ts",
      "import": "./dist/campaign.js"
    },
    "./campaignEvents": {
      "types": "./dist/campaignEvents.d.ts",
      "import": "./dist/campaignEvents.js"
    },
    "./outcomeDeck": {
      "types": "./dist/outcomeDeck.d.ts",
      "import": "./dist/outcomeDeck.js"
    },
    "./counterCards": {
      "types": "./dist/counterCards.d.ts",
      "import": "./dist/counterCards.js"
    },
    "./adventureModule": {
      "types": "./dist/adventureModule.d.ts",
      "import": "./dist/adventureModule.js"
    },
    "./adventureModuleAuthoring": {
      "types": "./dist/adventureModuleAuthoring.d.ts",
      "import": "./dist/adventureModuleAuthoring.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js"
    },
    "./imageGeneration": {
      "types": "./dist/imageGeneration.d.ts",
      "import": "./dist/imageGeneration.js"
    },
    "./workflowLab": {
      "types": "./dist/workflowLab.d.ts",
      "import": "./dist/workflowLab.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../scripts/rewrite-relative-imports.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
