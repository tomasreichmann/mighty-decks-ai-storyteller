PORT=8081
CORS_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
# Text provider: "openrouter" (default, uses API) or "claude_cli" (local CLI)
AI_TEXT_PROVIDER=openrouter
# Claude CLI settings (only used when AI_TEXT_PROVIDER=claude_cli)
CLAUDE_CLI_MODEL=claude-sonnet-4-20250514
CLAUDE_CLI_MAX_CONCURRENT=2
OPENROUTER_API_KEY=replace-me
FAL_API_KEY=replace-me
LEONARDO_API_KEY=replace-me
FAL_API_BASE_URL=https://api.fal.ai/v1
FAL_QUEUE_BASE_URL=https://queue.fal.run
LEONARDO_BASE_URL=https://cloud.leonardo.ai/api/rest/v1
OR_TEXT_NARRATIVE_MODEL=deepseek/deepseek-v3.2
OR_TEXT_SCENE_MODEL=google/gemini-2.5-flash-lite
OR_TEXT_OUTCOME_MODEL=google/gemini-2.5-flash-lite
OR_TEXT_CONTINUITY_MODEL=google/gemini-2.5-flash-lite
OR_TEXT_PITCH_MODEL=deepseek/deepseek-v3.2
OR_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
OR_IMAGE_MODEL_FALLBACK=google/gemini-2.5-flash-image-preview
WF_OR_FAST_TEXT_MODEL=google/gemini-2.5-flash-lite
WF_OR_HQ_TEXT_MODEL=anthropic/claude-sonnet-4.6
WF_OR_FAST_TOOL_MODEL=google/gemini-2.5-flash
WF_OR_HQ_TOOL_MODEL=anthropic/claude-sonnet-4.6
WF_OR_FAST_VISION_MODEL=google/gemini-2.5-flash
WF_OR_HQ_VISION_MODEL=google/gemini-2.5-pro
WF_FAL_FAST_IMAGE_MODEL=fal-ai/flux/schnell
WF_FAL_HQ_IMAGE_MODEL=fal-ai/flux-pro/kontext/text-to-image
WF_FAL_FAST_TTS_MODEL=fal-ai/minimax/speech-02-turbo
WF_FAL_HQ_TTS_MODEL=fal-ai/minimax/speech-02-hd
WF_FAL_FAST_STT_MODEL=fal-ai/wizper
WF_FAL_HQ_STT_MODEL=fal-ai/speech-to-text
TEXT_CALL_TIMEOUT_MS=30000
TURN_DEADLINE_MS=18000
IMAGE_TIMEOUT_MS=180000
AI_RETRY_COUNT=1
VOTE_TIMEOUT_MS=60000
WORKFLOW_RUN_TIMEOUT_MS=180000
WORKFLOW_DEFAULT_RETRY_COUNT=1
WORKFLOW_TEXT_STEP_TIMEOUT_MS=30000
WORKFLOW_TOOL_STEP_TIMEOUT_MS=45000
WORKFLOW_VISION_STEP_TIMEOUT_MS=45000
WORKFLOW_IMAGE_STEP_TIMEOUT_MS=120000
WORKFLOW_TTS_STEP_TIMEOUT_MS=60000
WORKFLOW_STT_STEP_TIMEOUT_MS=60000
WORKFLOW_LAB_LOG_DIR=output/workflow-lab-runs
MAX_ACTIVE_ADVENTURES=1
CLIENT_IDLE_TIMEOUT_MS=900000
DEBUG_MODE=false
DEBUG_LOG_DIR=logs/adventures
ADVENTURE_SNAPSHOT_DIR=output/adventure-snapshots
ADVENTURE_SNAPSHOT_HISTORY_LIMIT=20
ADVENTURE_SNAPSHOT_WRITE_DEBOUNCE_MS=400
ADVENTURE_ARTIFACT_DIR=output/adventure-artifacts
ADVENTURE_MODULE_DIR=output/adventure-modules
IMAGE_OUTPUT_DIR=output/generated-images
IMAGE_MAX_ACTIVE_JOBS=4
IMAGE_RATE_LIMIT_PER_MINUTE=10
FAL_POLL_INTERVAL_MS=1000
FAL_POLL_TIMEOUT_MS=180000
LEONARDO_POLL_INTERVAL_MS=1000
LEONARDO_POLL_TIMEOUT_MS=180000
