{
  "name": "@mighty-decks/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare:spec": "pnpm -C ../../spec build",
    "predev": "pnpm run prepare:spec",
    "dev": "tsx watch src/index.ts",
    "preserve": "pnpm run build",
    "serve": "node dist/index.js",
    "prebuild": "pnpm run prepare:spec",
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-relative-imports.mjs dist",
    "start": "node dist/index.js",
    "pretypecheck": "pnpm run prepare:spec",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm run prepare:spec",
    "test": "node scripts/run-tests.mjs",
    "presmoke:campaign-flow": "pnpm run prepare:spec",
    "smoke:campaign-flow": "tsx --test test/campaignFlow.smoke.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@mighty-decks/spec": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
